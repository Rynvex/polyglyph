            { "jp": "炭酸水", "kana": "たんさんすい" },
            { "jp": "を", "kana": "を" },
            { "jp": "一本", "kana": "いっぽん" },
            { "jp": "と", "kana": "と" },
            { "jp": "赤", "kana": "あか" },
            { "jp": "ワイン", "kana": "わいん" },
            { "jp": "一杯", "kana": "いっぱい" },
            { "jp": "お願いします。", "kana": "おねがいします" }
