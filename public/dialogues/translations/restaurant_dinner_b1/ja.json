    "t13": { "text": "厨房に伝えます。お飲み物すぐお持ちします。" },
    "t14": {
      "templates": [
        {
          "id": "t14.0",
          "display": "ありがとう。食べ終わったらお会計を分けてください。",
          "display_furigana": [
            { "jp": "ありがとう。", "kana": "ありがとう" },
            { "jp": "食べ終わったら", "kana": "たべおわったら" },
